# =============================================
# Notion ブログ連携
# =============================================
# Notion インテグレーションのシークレットキー
# https://www.notion.so/my-integrations で作成
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ブログ記事を管理する Notion データベースの ID
# データベースページURLの ?v= の前の32文字
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================
# EmailJS（メール送信用）
# =============================================
# https://www.emailjs.com/ で取得
# VITE_ プレフィックスで Vite がクライアントに公開
# VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
# VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
# VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxx
